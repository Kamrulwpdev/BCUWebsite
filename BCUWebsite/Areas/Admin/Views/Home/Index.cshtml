@model BCUWebsite.Models.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-3">
    <div class="col-xl-3 col-sm-6">
        <div class="card stat-card h-100 shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-uppercase text-muted mb-2">Total Revenue</p>
                    <h3 class="mb-1">$3.46K</h3>
                    <p class="mb-0 text-muted">+4.3% from last week</p>
                </div>
                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                    <i class="fas fa-dollar-sign"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="card stat-card h-100 shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-uppercase text-muted mb-2">Total Profit</p>
                    <h3 class="mb-1">$45.2K</h3>
                    <p class="mb-0 text-muted">+4.35% growth</p>
                </div>
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="fas fa-chart-line"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="card stat-card h-100 shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-uppercase text-muted mb-2">Total Courses</p>
                    <h3 class="mb-1">@Model.TotalCourses</h3>
                    <p class="mb-0 text-muted">@Model.TotalCourses new items</p>
                </div>
                <div class="stat-icon bg-info bg-opacity-10 text-info">
                    <i class="fas fa-book-open"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="card stat-card h-100 shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-uppercase text-muted mb-2">Total Users</p>
                    <h3 class="mb-1">1</h3>
                    <p class="mb-0 text-muted">Admin accounts</p>
                </div>
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="fas fa-users"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-4">
    <div class="col-xl-8">
        <div class="card card-custom chart-card">
            <div class="card-body py-4 px-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h5 class="mb-1">Total Revenue</h5>
                        <small class="text-muted">12.04.2022 - 12.05.2022</small>
                    </div>
                    <div class="btn-group" role="group" aria-label="Chart filter">
                        <button type="button" class="btn btn-sm btn-outline-secondary active">Day</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary">Week</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary">Month</button>
                    </div>
                </div>
                <canvas id="revenueChart" class="w-100" height="260"></canvas>
            </div>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="card card-custom h-100">
            <div class="card-body py-4 px-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h5 class="mb-1">Profit this week</h5>
                        <small class="text-muted">This Week</small>
                    </div>
                    <span class="badge bg-primary bg-opacity-10 text-primary">Sales</span>
                </div>
                <canvas id="profitChart" class="w-100 mb-3" height="220"></canvas>
                <div class="row text-center gx-2">
                    <div class="col-6">
                        <div class="border rounded-3 p-3">
                            <h6 class="mb-1">Sales</h6>
                            <strong>2,450</strong>
                            <div class="small text-success">+2.59%</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="border rounded-3 p-3">
                            <h6 class="mb-1">Revenue</h6>
                            <strong>$18.3K</strong>
                            <div class="small text-success">+4.2%</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-4">
    <div class="col-xl-7">
        <div class="card card-custom h-100">
            <div class="card-body py-4 px-4">
                <h5 class="mb-4">Latest courses</h5>
                @foreach (var course in Model.RecentCourses)
                {
                    <div class="recent-item">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <h6 class="mb-1">@course.Title</h6>
                                <small class="text-muted">@course.Category</small>
                            </div>
                            <span class="badge bg-light text-dark">@course.DisplayOrder</span>
                        </div>
                        <p class="mb-0 text-muted">@course.Description</p>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-xl-5">
        <div class="card card-custom h-100">
            <div class="card-body py-4 px-4">
                <h5 class="mb-4">Latest news</h5>
                @foreach (var news in Model.RecentNews)
                {
                    <div class="recent-item">
                        <div class="mb-2">
                            <h6 class="mb-1">@news.Title</h6>
                            <small class="text-muted">@news.PublishedDate.ToString("dd MMM yyyy")</small>
                        </div>
                        <p class="mb-0 text-muted">@news.Content</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const revenueCtx = document.getElementById('revenueChart');
        if (revenueCtx) {
            new Chart(revenueCtx, {
                type: 'line',
                data: {
                    labels: ['Sep', 'Oct', 'Nov', 'Dec', 'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug'],
                    datasets: [{
                        label: 'Revenue',
                        data: [1200, 1400, 1550, 1480, 1700, 1800, 1950, 2120, 2280, 2400, 2600, 2850],
                        borderColor: '#4f93ff',
                        backgroundColor: 'rgba(79, 147, 255, 0.15)',
                        fill: true,
                        tension: 0.35,
                        pointRadius: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        x: {
                            grid: { display: false },
                            ticks: { color: '#6c757d' }
                        },
                        y: {
                            grid: { color: 'rgba(0,0,0,0.05)' },
                            ticks: { color: '#6c757d' }
                        }
                    }
                }
            });
        }

        const profitCtx = document.getElementById('profitChart');
        if (profitCtx) {
            new Chart(profitCtx, {
                type: 'bar',
                data: {
                    labels: ['M', 'T', 'W', 'T', 'F', 'S', 'S'],
                    datasets: [
                        {
                            label: 'Sales',
                            data: [32, 42, 38, 48, 55, 60, 68],
                            backgroundColor: '#4f93ff',
                            borderRadius: 10,
                            barThickness: 18
                        },
                        {
                            label: 'Revenue',
                            data: [28, 35, 30, 42, 50, 55, 62],
                            backgroundColor: 'rgba(79, 147, 255, 0.35)',
                            borderRadius: 10,
                            barThickness: 18
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        x: {
                            grid: { display: false },
                            ticks: { color: '#6c757d' }
                        },
                        y: {
                            display: false
                        }
                    }
                }
            });
        }
    </script>
}
