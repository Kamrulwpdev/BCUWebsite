@model IEnumerable<BCUWebsite.Models.NewsArticle>

@{
    ViewData["Title"] = "Manage News";
}

<div class="mb-3">
    <a class="btn btn-primary" asp-action="Create">Create News</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Published</th>
            <th>Date</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var article in Model)
        {
            <tr>
                <td>@article.Title</td>
                <td>@(article.IsPublished ? "Yes" : "No")</td>
                <td>@article.PublishedDate.ToString("yyyy-MM-dd")</td>
                <td>
                    <a class="btn btn-sm btn-secondary" asp-action="Edit" asp-route-id="@article.Id">Edit</a>
                    <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@article.Id">Details</a>
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@article.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
