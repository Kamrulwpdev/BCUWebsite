@model BCUWebsite.Models.NewsArticle

@{
    ViewData["Title"] = "News Details";
}

<div class="mb-3">
    <h4>@Model.Title</h4>
    <p class="text-muted">Published on @Model.PublishedDate.ToString("yyyy-MM-dd")</p>
    <p><strong>Published:</strong> @(Model.IsPublished ? "Yes" : "No")</p>
    <div class="mb-3">@Html.Raw(Model.Content)</div>
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" class="img-fluid" alt="News image" style="max-width:400px;" />
    }
</div>

<a asp-action="Index" class="btn btn-secondary">Back</a>
