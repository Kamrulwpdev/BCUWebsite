@model BCUWebsite.Models.Course

@{
    ViewData["Title"] = "Course Details";
}

<div class="mb-3">
    <h4>@Model.Title</h4>
    <p><strong>Category:</strong> @Model.Category</p>
    <p><strong>Description:</strong> @Model.Description</p>
    <p><strong>Order:</strong> @Model.DisplayOrder</p>
    <p><strong>Promoted:</strong> @(Model.IsPromoted ? "Yes" : "No")</p>
    <p><strong>Created At:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</p>
    @if (Model.UpdatedAt.HasValue)
    {
        <p><strong>Updated At:</strong> @Model.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm")</p>
    }
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" class="img-fluid" alt="Course image" style="max-width:400px;" />
    }
</div>

<a asp-action="Index" class="btn btn-secondary">Back</a>
