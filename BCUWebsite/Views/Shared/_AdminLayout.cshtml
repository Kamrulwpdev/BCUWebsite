<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
        body {
            background: #f3f6fd;
        }
        .admin-sidebar {
            background-color: #0b1d40;
            min-height: 100vh;
            padding: 24px 0;
            color: #fff;
        }
        .sidebar-brand {
            padding: 0 24px 24px;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }
        .sidebar-brand h4 {
            color: #fff;
            margin: 0;
            font-weight: 700;
        }
        .sidebar-brand p {
            margin: 6px 0 0;
            color: rgba(255,255,255,0.65);
            font-size: 0.9rem;
        }
        .sidebar-section {
            padding: 20px 16px;
        }
        .sidebar-heading {
            text-transform: uppercase;
            color: rgba(255,255,255,0.55);
            font-size: 0.78rem;
            letter-spacing: 0.06em;
            margin-bottom: 12px;
        }
        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            color: rgba(255,255,255,0.78);
            padding: 12px 16px;
            border-radius: 12px;
            margin-bottom: 6px;
            transition: background 0.2s ease, color 0.2s ease;
        }
        .sidebar-link:hover,
        .sidebar-link.active {
            background: rgba(255,255,255,0.08);
            color: #fff;
        }
        .sidebar-link i {
            width: 24px;
            text-align: center;
        }
        .sidebar-footer {
            margin-top: 24px;
            padding: 16px;
            border-top: 1px solid rgba(255,255,255,0.08);
        }
        .sidebar-footer a {
            color: rgba(255,255,255,0.75);
            text-decoration: none;
        }
        .admin-topbar {
            padding: 18px 32px;
            background: #fff;
            border-bottom: 1px solid #e9ecef;
        }
        .admin-topbar .search-input {
            width: 100%;
            max-width: 420px;
            border-radius: 999px;
            border: 1px solid #dee2e6;
            padding: 10px 16px;
            box-shadow: none;
        }
        .admin-topbar .topbar-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .topbar-icon {
            width: 44px;
            height: 44px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #f8f9fc;
            border-radius: 50%;
            color: #495057;
            border: 1px solid #e9ecef;
        }
        .topbar-user {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 12px;
            border-radius: 999px;
            background: #f8f9fc;
        }
        .topbar-user img {
            width: 42px;
            height: 42px;
            border-radius: 50%;
        }
        .admin-content {
            padding: 28px 32px;
            min-height: calc(100vh - 78px);
        }
        .card-custom {
            border: 0;
            border-radius: 18px;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
        }
        .card-custom .card-body {
            padding: 22px;
        }
        .stat-card {
            border-radius: 1.5rem;
            overflow: hidden;
            border: 1px solid rgba(0,0,0,0.08);
        }
        .stat-card .card-body {
            padding: 22px;
        }
        .stat-card .stat-icon {
            width: 54px;
            height: 54px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 18px;
            background: rgba(13, 110, 253, 0.1);
            color: #0d6efd;
        }
        .stat-card .stat-change {
            color: #28a745;
            font-weight: 700;
        }
        .chart-card {
            min-height: 340px;
        }
        .chart-placeholder {
            height: 280px;
            border-radius: 18px;
            background: linear-gradient(180deg, rgba(113,155,255,0.16) 0%, rgba(255,255,255,0.78) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #6c757d;
            font-size: 0.95rem;
        }
        .trend-label {
            color: #28a745;
            font-weight: 600;
        }
        .recent-item {
            border-radius: 1rem;
            background: #fff;
            border: 1px solid #eaeaea;
            padding: 16px;
            margin-bottom: 12px;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav class="col-md-2 admin-sidebar px-0">
                <div class="sidebar-brand">
                    <h4>BCU Admin</h4>
                    <p>University dashboard</p>
                </div>
                <div class="sidebar-section">
                    <p class="sidebar-heading">Menu</p>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" href="/Admin/Home/Index">
                        <i class="fas fa-chart-pie"></i> Dashboard
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Courses" ? "active" : "")" href="/Admin/Courses">
                        <i class="fas fa-book"></i> Courses
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "News" ? "active" : "")" href="/Admin/News">
                        <i class="fas fa-newspaper"></i> News
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ContentBlocks" ? "active" : "")" href="/Admin/ContentBlocks">
                        <i class="fas fa-th-large"></i> Content Blocks
                    </a>
                </div>
                <div class="sidebar-section">
                    <p class="sidebar-heading">Support</p>
                    <a class="sidebar-link" href="#">
                        <i class="fas fa-comments"></i> Messages
                    </a>
                    <a class="sidebar-link" href="#">
                        <i class="fas fa-info-circle"></i> Help
                    </a>
                </div>
                <div class="sidebar-footer px-3">
                    <a href="/" class="d-flex align-items-center gap-2"><i class="fas fa-globe"></i> View public site</a>
                </div>
            </nav>

            <!-- Main Content -->
            <main class="col-md-10 ms-sm-auto px-0">
                <div class="admin-topbar d-flex align-items-center justify-content-between">
                    <div class="w-100 me-3">
                        <form class="d-flex align-items-center gap-2">
                            <i class="fas fa-search text-muted"></i>
                            <input type="search" class="form-control search-input" placeholder="Search for reports, users, or content" />
                        </form>
                    </div>
                    <div class="topbar-actions">
                        <button type="button" class="topbar-icon"><i class="fas fa-bell"></i></button>
                        <button type="button" class="topbar-icon"><i class="fas fa-envelope"></i></button>
                        <div class="topbar-user">
                            <img src="https://via.placeholder.com/42/C3D3FF/0b1d40?text=AD" alt="Admin" />
                            <div>
                                <div class="fw-bold">Admin</div>
                                <small class="text-muted">Administrator</small>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="admin-content">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
