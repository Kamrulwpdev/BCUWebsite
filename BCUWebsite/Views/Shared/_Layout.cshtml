<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Birmingham City University</title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Top Bar -->
    <div class="top-bar">
        <div class="container">
            <div class="row">
                <div class="col-md-6 d-none d-md-block">
                    <span>Birmingham City University</span>
                </div>
                <div class="col-md-6 text-end">
                    <a href="#">Student</a>
                    <span class="mx-2">|</span>
                    <a href="#">Staff</a>
                    <span class="mx-2">|</span>
                    <a href="#">Alumni</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Header -->
    <header>
        <div class="container">
            <nav class="navbar navbar-expand-lg navbar-light">
                <div class="container-fluid px-0">
                    <a class="navbar-brand" href="/">
                        <img src="~/images/bcu-logo.svg" alt="BCU Logo" height="60" onerror="this.src='https://via.placeholder.com/200x60/0a1e3c/ffffff?text=BCU'">
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="mainNavbar">
                        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                            <li class="nav-item"><a class="nav-link" href="#">Courses</a></li>
                            <li class="nav-item"><a class="nav-link" href="#">International</a></li>
                            <li class="nav-item"><a class="nav-link" href="#">Research</a></li>
                            <li class="nav-item"><a class="nav-link" href="#">About</a></li>
                            <li class="nav-item"><a class="nav-link" href="#">News</a></li>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <li class="nav-item"><a class="nav-link" href="/Identity/Account/Manage">Account</a></li>
                                <li class="nav-item">
                                    <form class="d-inline" method="post" action="/Identity/Account/Logout">
                                        <button type="submit" class="btn btn-link nav-link">Logout</button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item"><a class="nav-link" href="/Identity/Account/Login">Login</a></li>
                                <li class="nav-item"><a class="nav-link" href="/Identity/Account/Register">Register</a></li>
                            }
                            <li class="nav-item">
                                <a class="btn btn-primary ms-lg-3" href="#">
                                    <i class="fas fa-search"></i> Search
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </div>
    </header>

    <!-- Main Content -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-lg-3 col-md-6 mb-4">
                    <h5>About BCU</h5>
                    <ul class="list-unstyled">
                        <li><a href="#">Our history</a></li>
                        <li><a href="#">Vision and strategy</a></li>
                        <li><a href="#">Governance</a></li>
                        <li><a href="#">Contact us</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <h5>Study</h5>
                    <ul class="list-unstyled">
                        <li><a href="#">Undergraduate</a></li>
                        <li><a href="#">Postgraduate</a></li>
                        <li><a href="#">International</a></li>
                        <li><a href="#">How to apply</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <h5>Life at BCU</h5>
                    <ul class="list-unstyled">
                        <li><a href="#">Accommodation</a></li>
                        <li><a href="#">Student support</a></li>
                        <li><a href="#">Clubs and societies</a></li>
                        <li><a href="#">Campus maps</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <h5>Connect</h5>
                    <div class="social-links">
                        <a href="#" class="me-2"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="me-2"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="me-2"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="me-2"><i class="fab fa-youtube"></i></a>
                        <a href="#" class="me-2"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                    <div class="mt-3">
                        <p class="mb-1"><i class="fas fa-phone"></i> +44 (0)121 331 5000</p>
                        <p><i class="fas fa-envelope"></i> info@bcu.ac.uk</p>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <div class="row">
                    <div class="col-md-6">
                        <small>&copy; 2026 Birmingham City University</small>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <small>
                            <a href="#">Privacy Policy</a>
                            <span class="mx-2">|</span>
                            <a href="#">Terms of Use</a>
                            <span class="mx-2">|</span>
                            <a href="#">Accessibility</a>
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Custom JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
