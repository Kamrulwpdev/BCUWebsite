@{
    ViewData["Title"] = "About us";
}

<section class="about-hero">
    <div class="overlay">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <h1 class="display-4">About us</h1>
                    <p class="lead">We are Birmingham City University — rooted in the city, reaching beyond. Discover our story, our people, and how we make an impact.</p>
                    <p class="about-cta">
                        <a class="btn btn-light btn-lg me-2" href="#our-story">Our story</a>
                        <a class="btn btn-outline-light btn-lg" href="#contact">Contact us</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="container feature-section mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <div class="about-card">
                <h2>Beyonders.</h2>
                <p>We champion bold thinking and practical learning that transforms lives and industries. Our campuses, partners and staff create opportunities for our students to reach beyond their ambitions.</p>
                <p><a class="btn btn-primary" href="#">Read more</a></p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="about-card">
                <h5>Practical information</h5>
                <ul class="list-unstyled">
                    <li><a href="#">Maps and campuses</a></li>
                    <li><a href="#">Contact us</a></li>
                    <li><a href="#">Our subjects</a></li>
                </ul>
            </div>
        </div>
    </div>

    <div id="our-story" class="row mt-4">
        <div class="col-12">
            <h3>Our story</h3>
        </div>
        <div class="col-md-4 mt-3">
            <div class="about-card">
                <h5>Our history</h5>
                <p>Find out how we've evolved and the milestones that shaped our university.</p>
                <p><a class="btn btn-outline-primary" href="#">Learn more</a></p>
            </div>
        </div>
        <div class="col-md-4 mt-3">
            <div class="about-card">
                <h5>Our staff community</h5>
                <p>Meet the people who teach, research and support our students.</p>
                <p><a class="btn btn-outline-primary" href="#">Learn more</a></p>
            </div>
        </div>
        <div class="col-md-4 mt-3">
            <div class="about-card">
                <h5>Widening participation</h5>
                <p>How we create access and opportunity for learners from all backgrounds.</p>
                <p><a class="btn btn-outline-primary" href="#">Learn more</a></p>
            </div>
        </div>
    </div>
</section>

<section id="contact" class="container mt-5 mb-5">
    <div class="row">
        <div class="col-md-6">
            <h4>Contact details</h4>
            <p>Tel: +44 (0)121 331 5000</p>
            <p>Email: info@bcu.ac.uk</p>
        </div>
        <div class="col-md-6">
            <h4>Maps and campuses</h4>
            <p>Find out how to get to our campuses and facilities.</p>
            <p><a class="btn btn-outline-primary" href="#">Learn more</a></p>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Minor interaction placeholder for the About page
        console.log('About page loaded');
    </script>
}
